 RowBox[{
  RowBox[{"f", "[", "\[Theta]_", "]"}], ":=", 
  RowBox[{
   RowBox[{"J", " ", 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"i", "=", "1"}], 
      RowBox[{"L", "-", "1"}]], " ", 
